{
  "name": "@velora/shared",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./velora-site": {
      "types": "./dist/velora-site.d.ts",
      "default": "./dist/velora-site.js"
    },
    "./velora-site-node": {
      "types": "./dist/velora-site-node.d.ts",
      "default": "./dist/velora-site-node.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "hash-wasm": "^4.12.0",
    "ignore": "^7.0.5",
    "zod": "^4.0.5"
  }
