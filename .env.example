NODE_ENV=development
PORT=3000
APP_BASE_URL=REPLACE_WITH_PUBLIC_URL
DATABASE_URL=postgres://REPLACE_WITH_GENERATED_SECRET:REPLACE_WITH_GENERATED_SECRET@localhost:5432/velora
REDIS_URL=redis://localhost:6379

ACCESS_TOKEN_SECRET=REPLACE_WITH_GENERATED_SECRET
REFRESH_TOKEN_SECRET=REPLACE_WITH_GENERATED_SECRET
SESSION_SECRET=REPLACE_WITH_GENERATED_SECRET
LICENSE_HMAC_SECRET=REPLACE_WITH_GENERATED_SECRET

MEMBERSHIP_SIGNING_PRIVATE_KEY_BASE64=REPLACE_WITH_GENERATED_SECRET
MEMBERSHIP_SIGNING_PUBLIC_KEY_BASE64=REPLACE_WITH_GENERATED_SECRET

ZONE_REGISTRY_SIGNING_PRIVATE_KEY_BASE64=REPLACE_WITH_GENERATED_SECRET
ZONE_REGISTRY_SIGNING_PUBLIC_KEY_BASE64=REPLACE_WITH_GENERATED_SECRET

CATEGORY_SIGNING_PRIVATE_KEY_BASE64=REPLACE_WITH_GENERATED_SECRET
CATEGORY_SIGNING_PUBLIC_KEY_BASE64=REPLACE_WITH_GENERATED_SECRET

RELEASE_SIGNING_PRIVATE_KEY_BASE64=REPLACE_WITH_GENERATED_SECRET
RELEASE_SIGNING_PUBLIC_KEY_BASE64=REPLACE_WITH_GENERATED_SECRET

CONTROL_API_SERVER_SIGNING_PRIVATE_KEY_BASE64=REPLACE_WITH_GENERATED_SECRET
CONTROL_API_SERVER_SIGNING_PUBLIC_KEY_BASE64=REPLACE_WITH_GENERATED_SECRET

S3_ENDPOINT=https://s3.example.invalid
S3_REGION=eu-west-1
S3_BUCKET=REPLACE_WITH_S3_BUCKET
S3_ACCESS_KEY_ID=REPLACE_WITH_GENERATED_SECRET
S3_SECRET_ACCESS_KEY=REPLACE_WITH_GENERATED_SECRET
S3_FORCE_PATH_STYLE=false

CERTIFICATE_DURATION_DAYS=30
OFFLINE_GRACE_DAYS=7
MAX_DEVICES_DEFAULT=3
MAX_SITE_SIZE_MB=250
MAX_SITE_FILE_COUNT=5000
MAX_CACHE_SIZE_GB=10
VELORA_CHUNK_SIZE_BYTES=1048576
TARGET_REPLICATION_FACTOR=5

ZONE_REQUEST_RESERVATION_HOURS=48
ZONE_REQUEST_TARGET_REVIEW_HOURS=24
ADMIN_AUTO_LOCK_MINUTES=10
ADMIN_SESSION_MINUTES=15

BOOTSTRAP_REFRESH_MINUTES=15
TELEMETRY_ENABLED_DEFAULT=false
AI_MODULE_ENABLED=false
ADMIN_USERNAME=REPLACE_WITH_ADMIN_USERNAME
# Beta logical node cluster. Keep disabled for first deploy, then enable after migrations and health checks.
VELORA_BETA_NODE_CLUSTER_ENABLED=false
VELORA_BETA_NODE_COUNT=3
VELORA_BETA_NODE_QUORUM=2
VELORA_BETA_NODE_HEARTBEAT_SECONDS=15
VELORA_BETA_NODE_OFFLINE_THRESHOLD_SECONDS=60
VELORA_BETA_NODE_MASTER_KEY=replace-with-generated-secret
VELORA_BETA_NODE_LEASE_SECONDS=45
VELORA_BETA_NODE_REPAIR_INTERVAL_SECONDS=60
VELORA_HEROKU_DYNO_PLAN=unknown
