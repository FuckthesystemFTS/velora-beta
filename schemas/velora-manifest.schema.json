{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://velora.dev/schemas/velora-manifest.schema.json",
  "title": "Velora Publisher Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "formatVersion",
    "address",
    "title",
    "description",
    "version",
    "category",
    "entrypoint",
    "requiredIdentityLevel",
    "usesVeloraSdk",
    "permissions",
    "allowedExternalOrigins",
    "visibility",
    "familySafe"
  ],
  "properties": {
    "formatVersion": { "type": "integer", "const": 1 },
    "address": {
      "type": "string",
      "minLength": 3,
      "maxLength": 80,
      "pattern": "^[a-z0-9](?:[a-z0-9-]{0,30}[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]{0,30}[a-z0-9])?)+$"
    },
    "title": { "type": "string", "minLength": 2, "maxLength": 80 },
    "description": { "type": "string", "minLength": 8, "maxLength": 240 },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]+)?$"
    },
    "category": {
      "type": "string",
      "enum": ["app", "education", "health", "media", "productivity", "shop", "social", "tool", "other"]
    },
    "entrypoint": {
      "type": "string",
      "pattern": "^(?!/)(?!.*\\.\\.)(?!.*\\\\).+\\.html$",
      "default": "index.html"
    },
    "requiredIdentityLevel": { "type": "integer", "minimum": 0, "maximum": 3 },
    "usesVeloraSdk": { "type": "boolean" },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity", "notifications", "mail", "payments", "wallet"],
      "properties": {
        "identity": { "type": "boolean" },
        "notifications": { "type": "boolean" },
        "mail": { "type": "boolean" },
        "payments": { "type": "boolean" },
        "wallet": { "type": "boolean" }
      }
    },
    "allowedExternalOrigins": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "string",
        "pattern": "^https://[A-Za-z0-9.-]+(?::[0-9]{2,5})?$"
      }
    },
    "visibility": { "type": "string", "enum": ["public", "unlisted"] },
    "familySafe": { "type": "boolean" },
    "keywords": {
      "type": "array",
      "maxItems": 12,
      "items": { "type": "string", "minLength": 2, "maxLength": 32 }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "requiredIdentityLevel": { "minimum": 1 } } },
      "then": { "properties": { "usesVeloraSdk": { "const": true } } }
    },
    {
      "if": { "properties": { "requiredIdentityLevel": { "maximum": 0 } } },
      "then": {
        "properties": {
          "permissions": {
            "properties": {
              "identity": { "const": false },
              "mail": { "const": false },
              "payments": { "const": false },
              "wallet": { "const": false }
            }
          }
        }
      }
    }
  ]
}
